# Copy to .env.local for local dev, OR set these as Project Environment
# Variables in Vercel for production. .env.local is gitignored.
#
# All three vars MUST be prefixed `NEXT_PUBLIC_` — that's how Next.js exposes
# them to the browser bundle. Anything else stays server-side and won't be
# readable from React.

# Base URL of the Express HTTP API (auth, bots, etc).
# Local:       http://localhost:3001
# Production:  https://gambling-web-ui.onrender.com   (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:3001

# WebSocket URL for the poker game. Must use `wss://` in production because
# pokerxyz.vercel.app is HTTPS and browsers block mixed `ws://` connections.
# Local:       ws://localhost:3001
# Production:  wss://gambling-web-ui.onrender.com
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# Google OAuth — the SAME Web Application client id you put in the server's
# GOOGLE_CLIENT_ID. The Vercel deploy origin (https://pokerxyz.vercel.app)
# must be in the client's "Authorized JavaScript origins" list in Google
# Cloud Console.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
