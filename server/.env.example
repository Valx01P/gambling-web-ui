# Copy to .env and fill in real values. .env is gitignored.

# HTTP / WS server
PORT=3001

# Postgres connection (Railway gives you this URL; SSL is on by default).
DATABASE_URL=postgresql://user:password@host:port/dbname

# Disable TLS for local Postgres only. Leave unset / "true" in any deployed env.
DATABASE_SSL=true

# Google OAuth - create a Web Application client at
# https://console.cloud.google.com/apis/credentials
# Authorized JavaScript origins should include http://localhost:3000 (and your prod origin).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Symmetric secret used to sign session JWTs. Use `openssl rand -hex 48` for a strong value.
JWT_SECRET=replace-me-with-a-long-random-string
JWT_TTL_SECONDS=2592000

# Optional: comma-separated origins allowed by the API CORS layer (the WS server already accepts any).
CORS_ORIGINS=http://localhost:3000
