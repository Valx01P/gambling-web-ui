# Copy to .env and fill in real values. .env is gitignored.

# HTTP / WS server
PORT=3001

# Postgres connection (Railway gives you this URL; SSL is on by default).
DATABASE_URL=postgresql://user:password@host:port/dbname

# Disable TLS for local Postgres only. Leave unset / "true" in any deployed env.
DATABASE_SSL=true

# Google OAuth - create a Web Application client at
# https://console.cloud.google.com/apis/credentials
# Authorized JavaScript origins should include http://localhost:3000 (and your prod origin).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Symmetric secret used to sign session JWTs. Use `openssl rand -hex 48` for a strong value.
JWT_SECRET=replace-me-with-a-long-random-string
JWT_TTL_SECONDS=2592000

# Comma-separated origins the API will accept cross-origin requests from.
# MUST include the deployed frontend, otherwise the browser blocks every
# /api call. WS server is not origin-checked (it's fine for local dev), but
# you should still add the production origin here for the HTTP API.
#
# Local:       http://localhost:3000
# Production:  https://pokerxyz.vercel.app
# Multi:       https://pokerxyz.vercel.app,https://staging.example.com
CORS_ORIGINS=http://localhost:3000
